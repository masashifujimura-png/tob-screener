FROM python:3.13-slim

WORKDIR /app

COPY requirements-tob-web.txt .
RUN pip install --no-cache-dir -r requirements-tob-web.txt

COPY tob_dashboard_v2.py .
COPY .streamlit/ .streamlit/

EXPOSE 8501

HEALTHCHECK CMD curl --fail http://localhost:8501/_stcore/health || exit 1

ENTRYPOINT ["streamlit", "run", "tob_dashboard_v2.py", "--server.port=8501", "--server.address=0.0.0.0"]
